{{ 'shop-the-look.css' | asset_url | stylesheet_tag }}
<script src="{{ 'shop-the-look.js' | asset_url }}" defer></script>
<style>
  .shop-look-heading {
    --desktop-font-size: {{ section.settings.heading_font_size_desktop }}px;
    --mobile-font-size: {{ section.settings.heading_font_size_mobile }}px;
    font-size: var(--desktop-font-size);
  }

  @media screen and (max-width: 749px) {
    .shop-look-heading {
      font-size: var(--mobile-font-size);
    }
  }
</style>
<section class="shop-look-section page-width">

 <h2 class="shop-look-heading"
    style="font-size: {{ section.settings.heading_font_size_desktop }}px;">
  {{ section.settings.heading }}
</h2>

  <div class="shop-look-grid">

    {% for block in section.blocks %}
      {% assign product = block.settings.product %}

      {% if product %}
        <div
          class="shop-look-card"
          data-product-handle="{{ product.handle }}"
          {{ block.shopify_attributes }}
        >
          <img
            src="{{ product.featured_image | image_url: width:700 }}"
            alt="{{ product.title }}"
            loading="lazy"
          >

          <button
            type="button"
            class="shop-look-open"
            data-product="{{ product.handle }}"
            style="
              left: {{ block.settings.icon_left }}%;
              top: {{ block.settings.icon_top }}%;
            "
          >
            +
          </button>
        </div>
      {% else %}
        <div class="shop-look-card placeholder">
          {{ 'product-1' | placeholder_svg_tag }}
        </div>
      {% endif %}
    {% endfor %}

  </div>
</section>

<div class="shop-look-popup" data-bonus-product="{{ section.settings.bonus_product.handle }}">
  <div class="shop-look-popup-overlay"></div>

  <div class="shop-look-popup-content">
    <button class="shop-look-close" type="button">×</button>
    <div class="shop-look-popup-inner"></div>
  </div>
</div>

{% schema %}
{
  "name": "Shop The Look",
  "tag": "section",
  "class": "section",

  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Heading",
      "default": "This vision in the wild."
    },
    {
      "type": "product",
      "id": "bonus_product",
      "label": "Bonus Product (Soft Winter Jacket)"
    },
    {
  "type": "range",
  "id": "heading_font_size_desktop",
  "label": "Heading Font Size (Desktop)",
  "min": 16,
  "max": 80,
  "step": 1,
  "unit": "px",
  "default": 48
},
{
  "type": "range",
  "id": "heading_font_size_mobile",
  "label": "Heading Font Size (Mobile)",
  "min": 12,
  "max": 60,
  "step": 1,
  "unit": "px",
  "default": 28
}
  ],

  "blocks": [
    {
      "type": "product",

      "name": "Product",

      "settings": [

        {
          "type": "product",
          "id": "product",
          "label": "Select Product"
        },
        {
  "type": "range",
  "id": "icon_left",
  "label": "Icon Horizontal Position",
  "min": 0,
  "max": 100,
  "step": 1,
  "unit": "%",
  "default": 50
},
{
  "type": "range",
  "id": "icon_top",
  "label": "Icon Vertical Position",
  "min": 0,
  "max": 100,
  "step": 1,
  "unit": "%",
  "default": 50
}

      ]
    }
  ],

  "max_blocks": 6,

  "presets": [
    {
      "name": "Shop The Look",

      "blocks": [
        {
          "type": "product"
        },
        {
          "type": "product"
        },
        {
          "type": "product"
        },
        {
          "type": "product"
        },
        {
          "type": "product"
        },
        {
          "type": "product"
        }
      ]
    }
  ]
}
{% endschema %}